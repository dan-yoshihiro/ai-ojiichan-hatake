{
  "name": "ai-ojiichan-system",
  "version": "0.1.0",
  "description": "AI農業先生 system documentation — published for AI ingestion. CSS-free, AI-first markup.",
  "license": "CC-BY-4.0",
  "scripts": {
    "deploy": "wrangler pages deploy . --project-name ai-ojiichan-system",
    "dev": "wrangler pages dev . --d1=LOGS_DB",
    "d1:create": "wrangler d1 create ai-ojiichan-logs",
    "d1:init": "wrangler d1 execute ai-ojiichan-logs --file=schema/init.sql",
    "d1:init:remote": "wrangler d1 execute ai-ojiichan-logs --remote --file=schema/init.sql",
    "d1:query": "wrangler d1 execute ai-ojiichan-logs --command",
    "d1:bot-summary": "wrangler d1 execute ai-ojiichan-logs --remote --file=queries/ai-bot-summary-7d.sql",
    "d1:daily-quality": "wrangler d1 execute ai-ojiichan-logs --remote --file=queries/daily-quality-7d.sql",
    "d1:legit-human": "wrangler d1 execute ai-ojiichan-logs --remote --file=queries/legit-human-7d.sql",
    "logs:tail": "wrangler pages deployment tail"
  },
  "dependencies": {
    "marked": "^12.0.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "wrangler": "^3.60.0",
    "typescript": "^5.4.0"
  }
}
